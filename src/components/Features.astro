---
const features = [
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    title: 'Complete Privacy',
    description: 'Zero server uploads. Every pixel stays on your machine. Your images are processed entirely in-browser using Web Workers.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    title: 'Smart Compression',
    description: 'Automatically tests multiple quality levels and formats. Picks the smallest output that maintains visual quality.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" /></svg>`,
    title: 'Format Conversion',
    description: 'Convert between JPEG, PNG, WebP, and AVIF. Use modern formats for dramatically smaller files with no quality loss.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z" /></svg>`,
    title: 'Bulk Processing',
    description: 'Drop up to 50 images at once. Download individually or grab everything as a single ZIP file.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>`,
    title: 'No Setup Required',
    description: 'No accounts. No API keys. No installation. Just open and start compressing — works on any modern browser.',
  },
  {
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>`,
    title: 'Mobile Friendly',
    description: 'Fully responsive. Works on phones and tablets with the same performance — Web Workers keep your UI smooth.',
  },
];
---

<section id="features" class="px-6 md:px-10 py-20">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <span class="text-gold text-xs font-semibold tracking-widest uppercase">Why CompressIMG</span>
      <h2 class="font-display text-3xl md:text-4xl text-white mt-3">
        Everything you need, nothing you don't
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature, i) => (
        <div class="feature-card bg-bg-card border border-border rounded-2xl p-7 flex flex-col gap-4">
          <div class="w-10 h-10 rounded-xl bg-gold/8 border border-gold/15 flex items-center justify-center text-gold">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-white font-semibold text-[15px]">{feature.title}</h3>
          <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
