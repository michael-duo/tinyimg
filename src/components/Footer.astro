---
const productLinks = [
  { label: 'Compress', href: '#tool' },
  { label: 'Convert', href: '#tool' },
  { label: 'Resize', href: '#tool' },
];

const resourceLinks = [
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'FAQ', href: '#faq' },
  { label: 'Features', href: '#features' },
];
---

<footer class="px-6 md:px-10 pt-16 pb-8 mt-8">
  <div class="max-w-6xl mx-auto">
    <div class="section-divider mb-12"></div>

    <div class="grid md:grid-cols-4 gap-10 md:gap-8 mb-14">
      <!-- Brand -->
      <div class="md:col-span-2 flex flex-col gap-4">
        <a href="/" class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-lg bg-gold/10 border border-gold/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-gold" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
          </div>
          <span class="text-lg font-bold tracking-wide text-white">
            Compress<span class="text-gold-gradient">IMG</span>
          </span>
        </a>
        <p class="text-text-secondary text-sm leading-relaxed max-w-xs">
          Free, private image compression powered entirely by your browser. No uploads, no sign-ups, no limits.
        </p>
      </div>

      <!-- Product -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-text-secondary mb-4">Product</h4>
        <nav class="flex flex-col gap-3">
          {productLinks.map(link => (
            <a href={link.href} class="text-sm text-text-secondary hover:text-white transition-colors">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-xs font-semibold tracking-widest uppercase text-text-secondary mb-4">Resources</h4>
        <nav class="flex flex-col gap-3">
          {resourceLinks.map(link => (
            <a href={link.href} class="text-sm text-text-secondary hover:text-white transition-colors">
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="section-divider"></div>
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-6">
      <p class="text-text-secondary text-xs">
        &copy; {new Date().getFullYear()} CompressImg. Built with privacy in mind.
      </p>
      <div class="flex items-center gap-2 text-text-secondary text-xs">
        <span class="w-1.5 h-1.5 rounded-full bg-success"></span>
        All processing happens on your device
      </div>
    </div>
  </div>
</footer>
