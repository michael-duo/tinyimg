---
const links = [
  { label: 'Compress', href: '#tool' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'FAQ', href: '#faq' },
];
---

<footer class="border-t border-border px-6 md:px-12 py-10 mt-8">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex flex-col items-center md:items-start gap-2">
      <a href="/" class="text-lg font-bold tracking-widest text-white">
        COMPRESS<span class="text-gold">IMG</span>
      </a>
      <p class="text-text-secondary text-xs text-center md:text-left">
        100% free &amp; private image compression. No uploads. No sign-up. No limits.
      </p>
    </div>
    <nav class="flex gap-6">
      {links.map(link => (
        <a
          href={link.href}
          class="text-xs tracking-wider uppercase text-text-secondary hover:text-gold transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
  <div class="max-w-5xl mx-auto mt-8 pt-6 border-t border-border text-center">
    <p class="text-text-secondary text-xs">
      &copy; {new Date().getFullYear()} CompressImg. Built with privacy in mind — your images stay on your device.
    </p>
  </div>
</footer>
