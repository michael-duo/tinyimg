---
const steps = [
  {
    number: '01',
    title: 'Upload Your Images',
    description: 'Drag and drop or click to select images. Supports JPEG, PNG, WebP, AVIF, and GIF formats. Process up to 50 files at once.',
  },
  {
    number: '02',
    title: 'Configure Settings',
    description: 'Choose your output format, quality level, and optional resize dimensions. Preview changes in real time before downloading.',
  },
  {
    number: '03',
    title: 'Download Results',
    description: 'Download individual compressed images or grab all files as a ZIP archive in one click. No sign-up required.',
  },
];
---

<section id="how-it-works" class="px-6 md:px-12 py-16">
  <h2 class="text-2xl md:text-3xl font-bold text-white text-center mb-12">
    How It <span class="text-gold">Works</span>
  </h2>
  <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
    {steps.map(step => (
      <div class="bg-bg-card border border-border rounded-2xl p-8 flex flex-col gap-4 hover:border-gold transition-colors">
        <span class="text-4xl font-extrabold text-gold opacity-60">{step.number}</span>
        <h3 class="text-lg font-semibold text-white">{step.title}</h3>
        <p class="text-text-secondary text-sm leading-relaxed">{step.description}</p>
      </div>
    ))}
  </div>
</section>
